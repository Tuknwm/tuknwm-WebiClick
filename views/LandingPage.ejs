<%- include('partials/header.ejs') %>

<!-- Curtain overlay -->
<div id="curtain"></div>

<div class="KotakTeksLP" id="lp-title">
  <h1 class="TeksAnimLP active">Modern Clicking Counter</h1>
  <h1 class="TeksAnimLP">Challenge Yourself</h1>
</div>
<p id="lp-sub">Know your limit at clicking, with saving point features.</p>

<div class="KotakOpsiLogin" id="lp-buttons">
  <div class="KotakRegister">
    <button class="RegisterButton" onclick="window.location.href='/register'">Register</button>
  </div>
  <div class="KotakLogin">
    <button class="LoginButton" onclick="window.location.href='/login'">Login</button>
  </div>
</div>

<p class="TeksGuest" id="lp-guest-text">Want To Play Without Account?</p>
<div class="KotakGuest" id="lp-guest-btn">
  <button class="GuestButton" onclick="window.location.href='/home'">Play As Guest</button>
</div>

<style>
  #curtain {
    position: fixed;
    inset: 0;
    background: #000;
    z-index: 9999;
    transform-origin: top;
  }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="/js/AnimTeks.js"></script>
<script>
  const els = ['#lp-title', '#lp-sub', '#lp-buttons', '#lp-guest-text', '#lp-guest-btn'];
  gsap.set(els, { opacity: 0, y: 40 });

  const tl = gsap.timeline();

  // Curtain slides up
  tl.to('#curtain', {
    scaleY: 0,
    duration: 0.9,
    ease: 'expo.inOut',
    transformOrigin: 'bottom'
  });

  // Elements stagger in
  tl.to(els, {
    opacity: 1,
    y: 0,
    duration: 0.6,
    stagger: 0.12,
    ease: 'power3.out'
  }, '-=0.2');
</script>
